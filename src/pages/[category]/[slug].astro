---
import Base from '../../layouts/Base.astro';
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

export function getStaticPaths() {
  const dataDir = join(process.cwd(), 'public', 'data');
  const structure = JSON.parse(readFileSync(join(dataDir, 'site-structure.json'), 'utf-8'));
  const searchDir = join(dataDir, 'search-pages');

  // Load search intents (google-suggestions or legacy)
  let allIntents: any[] = [];
  const suggestPath = join(dataDir, 'google-suggestions.json');
  const intentsPath = join(dataDir, 'search-intents.json');
  if (existsSync(suggestPath)) {
    allIntents = JSON.parse(readFileSync(suggestPath, 'utf-8')).suggestions || [];
  } else if (existsSync(intentsPath)) {
    allIntents = JSON.parse(readFileSync(intentsPath, 'utf-8')).intents || [];
  }

  // Index intents by megaCategory
  const intentsByMega: Record<string, any[]> = {};
  for (const i of allIntents) {
    if (!intentsByMega[i.megaCategory]) intentsByMega[i.megaCategory] = [];
    intentsByMega[i.megaCategory].push(i);
  }

  const paths: any[] = [];
  const globalSlugs = new Set(); // prevent slug collisions across types within same category

  for (const [megaSlug, cat] of Object.entries(structure.megaCategories) as [string, any][]) {
    const catIntents = intentsByMega[megaSlug] || [];

    // Build related intents index for this category
    const related = (items: any[], currentSlug: string) => {
      const current = items.find((i: any) => i.slug === currentSlug);
      if (!current) return items.filter((i: any) => i.slug !== currentSlug).slice(0, 8);
      const titleWords = new Set(current.title.toLowerCase().split(/\s+/).filter((w: string) => w.length > 2));
      return items
        .filter((i: any) => i.slug !== currentSlug)
        .map((i: any) => {
          const words = i.title.toLowerCase().split(/\s+/).filter((w: string) => w.length > 2);
          const overlap = words.filter((w: string) => titleWords.has(w)).length;
          return { ...i, relevance: overlap * 10000 + Math.min(i.productCount, 9999) };
        })
        .sort((a: any, b: any) => b.relevance - a.relevance)
        .slice(0, 8);
    };

    // 1. Subcategory pages - load static products from shards
    // Build category filter set for this mega
    const megaProducts: Record<string, any[]> = {};
    const shardFilesForMega = cat.shards?.map((s: any) => s.file) || [];
    for (const sf of shardFilesForMega.slice(0, 5)) {
      try {
        const shard = JSON.parse(readFileSync(join(dataDir, 'products', sf), 'utf-8'));
        for (const p of shard) {
          if (!p.i || !p.t || !p.l) continue;
          const c = p.c || '';
          if (!megaProducts[c]) megaProducts[c] = [];
          if (megaProducts[c].length < 50) megaProducts[c].push(p);
        }
      } catch {}
    }

    for (const sub of cat.subcategories.slice(0, 40)) {
      if (!sub.slug || sub.slug.trim() === '') continue;
      const key = `${megaSlug}:${sub.slug}`;
      if (globalSlugs.has(key)) continue;
      globalSlugs.add(key);

      // Get static products for this subcategory
      const filterNames = sub.originalNames || [sub.originalName || sub.name];
      let subProducts: any[] = [];
      for (const fn of filterNames) {
        if (megaProducts[fn]) subProducts.push(...megaProducts[fn]);
      }
      subProducts = subProducts.slice(0, 40);

      paths.push({
        params: { category: megaSlug, slug: sub.slug },
        props: {
          pageType: 'subcategory',
          megaSlug, megaName: cat.name,
          sub,
          products: subProducts,
          shardFiles: shardFilesForMega,
          relatedIntents: catIntents
            .sort((a: any, b: any) => b.productCount - a.productCount)
            .slice(0, 8),
          siblingSubcats: cat.subcategories
            .filter((s: any) => s.slug !== sub.slug && s.count >= 10)
            .slice(0, 8),
        },
      });
    }

    // 2. Search intent pages
    for (const intent of catIntents) {
      if (!intent.slug || intent.slug.trim() === '') continue;
      const key = `${megaSlug}:${intent.slug}`;
      if (globalSlugs.has(key)) continue; // skip if slug conflicts with a subcategory
      globalSlugs.add(key);

      // Read all products for sorting, then slice after sort
      let products: any[] = [];
      const pagePath = join(searchDir, `${intent.slug}.json`);
      if (existsSync(pagePath)) {
        try { products = JSON.parse(readFileSync(pagePath, 'utf-8')); } catch {}
      }

      paths.push({
        params: { category: megaSlug, slug: intent.slug },
        props: {
          pageType: 'intent',
          megaSlug, megaName: cat.name,
          intent,
          products,
          relatedIntents: related(catIntents, intent.slug),
          siblingSubcats: cat.subcategories
            .filter((s: any) => s.count >= 10)
            .slice(0, 6),
        },
      });
    }
  }

  return paths;
}

const {
  pageType, megaSlug, megaName,
  sub, shardFiles,
  intent, products,
  relatedIntents, siblingSubcats,
} = Astro.props;

const dataDir = join(process.cwd(), 'public', 'data');

// Load SEO content
let seo: any = {};
const contentPath = join(dataDir, 'content', 'seo-content.json');
if (existsSync(contentPath)) {
  const allSeo = JSON.parse(readFileSync(contentPath, 'utf-8'));
  if (pageType === 'subcategory') {
    seo = allSeo[`sub:${megaSlug}/${sub.slug}`] || {};
  } else {
    seo = allSeo[`search:${intent.slug}`] || {};
  }
}

// Common vars
const isSubcat = pageType === 'subcategory';
const pageName = isSubcat ? sub.name : intent.title;
const pageSlug = isSubcat ? sub.slug : intent.slug;
const canonical = `https://topbuy.ro/${megaSlug}/${pageSlug}/`;
const year = new Date().getFullYear();

const title = seo.metaTitle || `${pageName} - Recomandari ${year} | TopBuy.ro`;
const desc = seo.metaDescription || (isSubcat
  ? `${sub.count || ''}+ produse ${pageName} de la magazine verificate din Romania.`
  : `${intent.productCount || ''}+ produse ${pageName} de la magazine verificate din Romania.`);

// Product data slug for client-side loading (intents)
const intentSlug = !isSubcat ? intent.slug : '';
const totalCount = isSubcat ? (sub.count || 0) : (intent?.productCount || 0);

// Static first page products (for SEO - Google sees these), sorted by intent type
let staticProducts: any[] = [...(products || [])];
if (staticProducts.length > 0 && !isSubcat) {
  const iType = intent?.type || '';
  if (iType === 'top') {
    staticProducts.sort((a: any, b: any) => (Number(b.p) || 0) - (Number(a.p) || 0));
  } else if (iType === 'cheap') {
    staticProducts.sort((a: any, b: any) => (Number(a.p) || 999999) - (Number(b.p) || 999999));
  } else if (iType === 'best-of') {
    const prices = staticProducts.filter((p: any) => Number(p.p) > 0).map((p: any) => Number(p.p)).sort((a, b) => a - b);
    const median = prices[Math.floor(prices.length / 2)] || 0;
    staticProducts.sort((a: any, b: any) => Math.abs((Number(a.p) || 0) - median) - Math.abs((Number(b.p) || 0) - median));
  }
  staticProducts = staticProducts.slice(0, 40);
}

// For subcategory: filter categories for client-side shard loading
const filterCategories = isSubcat ? (sub.originalNames || [sub.originalName || sub.name]) : [];
const shardFilesForTemplate = isSubcat ? shardFiles : [];

// Split intro into readable paragraphs
function splitIntro(text: string): string[] {
  if (!text) return [];
  const parts = text.split('\n').filter((p: string) => p.trim());
  if (parts.length > 1) return parts;
  const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
  const paragraphs: string[] = [];
  let current = '';
  for (const s of sentences) {
    const t = s.trim();
    if (current.length + t.length > 350) { paragraphs.push(current.trim()); current = t; }
    else { current += (current ? ' ' : '') + t; }
  }
  if (current.trim()) paragraphs.push(current.trim());
  return paragraphs;
}

const introParagraphs = splitIntro(seo.intro || '');
---

<Base title={title} description={desc} canonical={canonical}>

  <div class="wrap">
    {/* ══ BREADCRUMB ══ */}
    <nav class="bc">
      <a href="/">Acasa</a> <span class="bc__sep">›</span>
      <a href={`/${megaSlug}/`}>{megaName}</a> <span class="bc__sep">›</span>
      <span>{pageName}</span>
    </nav>

    {/* ══ HEADER ══ */}
    <article>
      <h1 class="page-h1">{seo.h1 || pageName}</h1>
      <p class="updated-date">Actualizat: {new Date().toLocaleDateString('ro-RO', { month: 'long', year: 'numeric' })}</p>
      {introParagraphs.length > 0 && (
        <div class="cblock" style="margin-bottom:24px;">
          <div class="txt">
            {introParagraphs.map((p: string) => <p>{p}</p>)}
          </div>
        </div>
      )}
    </article>

    {/* ══ PRODUCTS ══ */}
    <div class="toolbar" id="toolbar">
      <div class="filters" id="filters" style="display:none;">
        <select class="sel" id="brandFilter"><option value="">Toate brandurile</option></select>
        <select class="sel" id="shopFilter"><option value="">Toate magazinele</option></select>
        <select class="sel" id="sortFilter">
          <option value="">Sortare</option>
          <option value="price-asc">Pret crescator</option>
          <option value="price-desc">Pret descrescator</option>
          <option value="name">Alfabetic</option>
        </select>
      </div>
      <span class="toolbar__cnt" id="productCount">{!isSubcat && staticProducts.length > 0 ? `${totalCount} produse` : ''}</span>
    </div>

    {/* Static first page (Google sees this) */}
    {staticProducts.length > 0 && (
      <div class="pgrid" id="staticGrid">
        {staticProducts.map((p: any) => (
          <a href={p.l} target="_blank" rel="nofollow noopener" class="prod">
            <div class="prod__img">
              <img src={p.i} alt={p.t} loading="lazy" onerror="this.onerror=null;this.parentElement.classList.add('prod__img--err')" />
            </div>
            <div class="prod__body">
              {p.b && <span class="prod__brand">{p.b}</span>}
              <span class="prod__title">{p.t}</span>
              {p.m && <span class="prod__shop">{p.m}</span>}
            </div>
            <span class="prod__cta">Verifica pret</span>
          </a>
        ))}
      </div>
    )}

    {/* Client-side grid (page 2+) */}
    <div class="pgrid" id="productGrid" style={staticProducts.length > 0 ? 'display:none' : ''}>
      <div class="loader"><i></i><i></i><i></i></div>
    </div>
    <div class="pag" id="pagination"></div>

    {/* ══ BUYING GUIDE ══ */}
    {!isSubcat && seo.guide && (
      <section class="cblock" style="margin-top:28px;">
        <h2 class="section-title">Cum alegi {pageName.charAt(0).toLowerCase() + pageName.slice(1)}</h2>
        <div class="txt">
          {seo.guide.split('\n').filter((p:string) => p.trim()).map((p: string) => <p>{p}</p>)}
        </div>
      </section>
    )}

    {/* ══ PROS / CONS ══ */}
    {!isSubcat && seo.pros?.length > 0 && (
      <div class="pc-box" style="margin-top:20px;">
        <div class="pc-col pc-col--pro">
          <div class="pc-col__h">Avantaje</div>
          <ul>{seo.pros.map((p: string) => <li>{p}</li>)}</ul>
        </div>
        <div class="pc-col pc-col--con">
          <div class="pc-col__h">Dezavantaje</div>
          <ul>{seo.cons?.map((c: string) => <li>{c}</li>)}</ul>
        </div>
      </div>
    )}

    {/* ══ TIPS ══ */}
    {seo.tips?.length > 0 && (
      <div class="tips-box">
        <h2 class="tips-box__h">Sfaturi pentru {pageName}</h2>
        <ul>
          {seo.tips.map((tip: string) => <li>{tip}</li>)}
        </ul>
      </div>
    )}

    {/* ══ FAQ ══ */}
    {seo.faq?.length > 0 && (
      <section class="faq">
        <h2 class="faq__h">Intrebari frecvente</h2>
        {seo.faq.map((item: any) => (
          <div class="faq__i" itemscope itemtype="https://schema.org/Question">
            <button class="faq__q" itemprop="name" onclick="this.classList.toggle('open');this.nextElementSibling?.classList.toggle('open');">
              <span>{item.q}</span>
              <span class="faq__q-ic">+</span>
            </button>
            <div class="faq__a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <span itemprop="text">{item.a}</span>
            </div>
          </div>
        ))}
      </section>
    )}

    {/* ══ SIBLING SUBCATS (silo lateral links) ══ */}
    {siblingSubcats?.length > 0 && (
      <section class="related">
        <h2 class="related__h">Categorii in {megaName}</h2>
        <div class="related__grid">
          {siblingSubcats.map((s: any) => (
            <a href={`/${megaSlug}/${s.slug}/`} class="related__link">
              <span class="related__title">{s.name}</span>
              <span class="related__cnt">{s.count.toLocaleString('ro')} produse</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ══ RELATED INTENTS (silo lateral links) ══ */}
    {relatedIntents?.length > 0 && (
      <section class="related">
        <h2 class="related__h">Cautari similare in {megaName}</h2>
        <div class="related__grid">
          {relatedIntents.map((r: any) => (
            <a href={`/${megaSlug}/${r.slug}/`} class="related__link">
              <span class="related__title">{r.title}</span>
              <span class="related__cnt">{r.productCount.toLocaleString('ro')} produse</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* ══ BACK TO PILLAR (silo upward link) ══ */}
    <div style="padding:24px 0;">
      <a href={`/${megaSlug}/`} class="back-link">← Inapoi la {megaName}</a>
    </div>
  </div>

  {/* ══ CLIENT-SIDE PRODUCT LOADING ══ */}
  <script define:vars={{ shardFiles: shardFilesForTemplate, filterCategories, intentSlug, isSubcat, staticCount: products?.length || 0, intentType: isSubcat ? '' : (intent?.type || '') }}>
    var PPG = 40;
    var allProducts = [], filtered = [], page = 1;
    var hasStaticPage = staticCount > 0;

    var catSet = {};
    if (isSubcat) {
      for (var ci = 0; ci < filterCategories.length; ci++) catSet[filterCategories[ci]] = true;
    }

    async function fetchJSON(url) {
      try { var r = await fetch(url); return r.ok ? r.json() : []; } catch { return []; }
    }

    async function fetchShards(files) {
      var results = [];
      for (var i = 0; i < files.length; i += 8) {
        var batch = files.slice(i, i + 8);
        var r = await Promise.all(batch.map(function(f) { return fetchJSON('/data/products/' + f) }));
        results.push.apply(results, r);
      }
      return results.flat();
    }

    // Seasonal sort: push off-season products to the end
    function seasonalSort(products) {
      var month = new Date().getMonth(); // 0=jan
      var winterWords = /iarna|geaca|cizme|fular|manusi|caciula|puf|thermal|fleece|ski|snowboard/i;
      var summerWords = /vara|sandale|sort|bermude|plaja|costume de baie|bikini|slapi|papuci/i;
      var isWinter = month >= 10 || month <= 2; // nov-mar
      var isSummer = month >= 4 && month <= 8; // may-sep
      if (!isWinter && !isSummer) return products;
      var offSeason = isWinter ? summerWords : winterWords;
      var onSeason = isWinter ? winterWords : summerWords;
      return products.sort(function(a, b) {
        var aOff = offSeason.test(a.t) ? 1 : 0;
        var bOff = offSeason.test(b.t) ? 1 : 0;
        var aOn = onSeason.test(a.t) ? -1 : 0;
        var bOn = onSeason.test(b.t) ? -1 : 0;
        return (aOff + aOn) - (bOff + bOn);
      });
    }

    async function load() {
      if (isSubcat) {
        var raw = await fetchShards(shardFiles.slice(0, 5));
        allProducts = seasonalSort(raw.filter(function(p) { return catSet[p.c] === true }));
        filtered = allProducts.slice();
        updateCount();
        if (!hasStaticPage) render();
        renderPag();
        buildFilters();
        if (shardFiles.length > 5) {
          var more = await fetchShards(shardFiles.slice(5));
          allProducts = seasonalSort(allProducts.concat(more.filter(function(p) { return catSet[p.c] === true })));
          filtered = allProducts.slice();
          updateCount();
          if (!hasStaticPage) render();
          renderPag();
          buildFilters();
        }
      } else {
        // Intent: load from search-pages JSON (page 1 is already static HTML)
        allProducts = await fetchJSON('/data/search-pages/' + intentSlug + '.json');
        // Sort by intent type
        if (intentType === 'top') {
          // Top: expensive first (premium products)
          allProducts.sort(function(a,b){return (b.p||0)-(a.p||0)});
        } else if (intentType === 'cheap') {
          // Cheap: cheapest first
          allProducts.sort(function(a,b){return (a.p||9999999)-(b.p||9999999)});
        } else if (intentType === 'best-of') {
          // Best-of: middle price range first (skip very cheap and very expensive)
          var prices = allProducts.filter(function(p){return p.p>0}).map(function(p){return p.p}).sort(function(a,b){return a-b});
          var median = prices[Math.floor(prices.length/2)] || 0;
          allProducts.sort(function(a,b){return Math.abs((a.p||0)-median) - Math.abs((b.p||0)-median)});
        } else if (intentType === 'product') {
          // Popular: mix by variety - alternate expensive/cheap for diverse display
          var withPrice = allProducts.filter(function(p){return p.p>0}).sort(function(a,b){return b.p-a.p});
          var mixed = [];
          var lo = 0, hi = withPrice.length - 1;
          while (lo <= hi) {
            if (lo <= hi) mixed.push(withPrice[lo++]);
            if (lo <= hi) mixed.push(withPrice[hi--]);
          }
          // Add products without price at the end
          allProducts = mixed.concat(allProducts.filter(function(p){return !p.p || p.p===0}));
        }
        filtered = allProducts.slice();
        updateCount();
        renderPag();
        buildFilters();
      }
    }

    function updateCount() {
      document.getElementById('productCount').textContent = filtered.length + ' produse';
    }

    function buildFilters() {
      var brands = {}, shops = {};
      for (var i = 0; i < allProducts.length; i++) {
        var p = allProducts[i];
        if (p.b) brands[p.b] = (brands[p.b] || 0) + 1;
        if (p.m) shops[p.m] = (shops[p.m] || 0) + 1;
      }
      // Sort by count desc
      var brandList = Object.entries(brands).sort(function(a,b){return b[1]-a[1]}).slice(0, 30);
      var shopList = Object.entries(shops).sort(function(a,b){return b[1]-a[1]}).slice(0, 20);

      var bf = document.getElementById('brandFilter');
      var sf = document.getElementById('shopFilter');
      if (bf && brandList.length > 1) {
        for (var i = 0; i < brandList.length; i++) {
          var o = document.createElement('option');
          o.value = brandList[i][0];
          o.textContent = brandList[i][0] + ' (' + brandList[i][1] + ')';
          bf.appendChild(o);
        }
      }
      if (sf && shopList.length > 1) {
        for (var i = 0; i < shopList.length; i++) {
          var o = document.createElement('option');
          o.value = shopList[i][0];
          o.textContent = shopList[i][0] + ' (' + shopList[i][1] + ')';
          sf.appendChild(o);
        }
      }
      document.getElementById('filters').style.display = 'flex';
    }

    function applyFilters() {
      var brand = document.getElementById('brandFilter').value;
      var shop = document.getElementById('shopFilter').value;
      var sort = document.getElementById('sortFilter').value;

      filtered = allProducts.filter(function(p) {
        if (brand && p.b !== brand) return false;
        if (shop && p.m !== shop) return false;
        return true;
      });

      if (sort === 'price-asc') filtered.sort(function(a,b){return (a.p||0)-(b.p||0)});
      if (sort === 'price-desc') filtered.sort(function(a,b){return (b.p||0)-(a.p||0)});
      if (sort === 'name') filtered.sort(function(a,b){return a.t.localeCompare(b.t)});

      page = 1;
      updateCount();
      goToPage(1);
    }

    document.getElementById('brandFilter')?.addEventListener('change', applyFilters);
    document.getElementById('shopFilter')?.addEventListener('change', applyFilters);
    document.getElementById('sortFilter')?.addEventListener('change', applyFilters);

    function goToPage(p) {
      page = p;
      // For intents: page 1 shows static grid, page 2+ shows dynamic grid
      if (hasStaticPage) {
        var staticGrid = document.getElementById('staticGrid');
        var dynamicGrid = document.getElementById('productGrid');
        if (page === 1) {
          if (staticGrid) staticGrid.style.display = '';
          if (dynamicGrid) dynamicGrid.style.display = 'none';
        } else {
          if (staticGrid) staticGrid.style.display = 'none';
          if (dynamicGrid) dynamicGrid.style.display = '';
          render();
        }
      } else {
        render();
      }
      renderPag();
      window.scrollTo({top:200,behavior:'smooth'});
    }

    function render() {
      var g = document.getElementById('productGrid');
      var s = (page-1)*PPG;
      var items = filtered.slice(s, s+PPG);
      if (!items.length) { g.innerHTML = '<div class="empty"><strong>Niciun produs gasit</strong></div>'; return; }
      g.innerHTML = items.map(function(p) {
        return '<a href="' + p.l + '" target="_blank" rel="nofollow noopener" class="prod">' +
          '<div class="prod__img"><img src="' + p.i + '" alt="' + (p.t||'').replace(/"/g,'&quot;') + '" loading="lazy" onerror="this.onerror=null;this.parentElement.classList.add(\'prod__img--err\')"/></div>' +
          '<div class="prod__body">' + (p.b ? '<span class="prod__brand">' + p.b + '</span>' : '') +
          '<span class="prod__title">' + p.t + '</span>' + (p.m ? '<span class="prod__shop">' + p.m + '</span>' : '') + '</div>' +
          '<span class="prod__cta">Verifica pret</span></a>';
      }).join('');
      renderPag();
    }

    function renderPag() {
      var el = document.getElementById('pagination');
      var tp = Math.ceil(filtered.length/PPG);
      if (tp <= 1) { el.innerHTML=''; return; }
      var h = '';
      if (page > 1) h += '<button class="pg" data-p="' + (page-1) + '">‹</button>';
      var s = Math.max(1,page-3), e = Math.min(tp,page+3);
      if (s > 1) h += '<button class="pg" data-p="1">1</button>';
      if (s > 2) h += '<span class="pg-d">…</span>';
      for (var i=s;i<=e;i++) h += '<button class="pg' + (i===page?' on':'') + '" data-p="' + i + '">' + i + '</button>';
      if (e < tp-1) h += '<span class="pg-d">…</span>';
      if (e < tp) h += '<button class="pg" data-p="' + tp + '">' + tp + '</button>';
      if (page < tp) h += '<button class="pg" data-p="' + (page+1) + '">›</button>';
      el.innerHTML = h;
      el.querySelectorAll('.pg').forEach(function(b) { b.addEventListener('click', function() {
        goToPage(+b.dataset.p);
      })});
    }

    load();
  </script>

  {/* ══ STRUCTURED DATA ══ */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": seo.h1 || pageName,
    "description": desc,
    "url": canonical,
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Acasa", "item": "https://topbuy.ro/" },
        { "@type": "ListItem", "position": 2, "name": megaName, "item": `https://topbuy.ro/${megaSlug}/` },
        { "@type": "ListItem", "position": 3, "name": pageName, "item": canonical }
      ]
    }
  })} />

  {!isSubcat && seo.faq?.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": seo.faq.map((f: any) => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    })} />
  )}
</Base>
