---
import Base from '../layouts/Base.astro';
---

<Base title="Contact - TopBuy.ro" description="Contacteaza echipa TopBuy.ro pentru intrebari sau sugestii.">
  <div class="wrap" style="max-width:800px;padding-top:28px;">
    <nav class="bc">
      <a href="/">Acasa</a> <span class="bc__sep">›</span> <span>Contact</span>
    </nav>

    <div class="cblock">
      <h1>Contact</h1>
      <div class="txt">
        <p>Pentru intrebari, sugestii sau colaborari, ne poti contacta la adresa de email:</p>
        <p><strong>contact@topbuy.ro</strong></p>
        <p>Raspundem de obicei in 1-2 zile lucratoare.</p>
        <p>TopBuy.ro nu vinde produse direct si nu proceseaza comenzi. Daca ai o problema cu o comanda, contacteaza direct magazinul de unde ai cumparat produsul.</p>
      </div>
    </div>
  </div>
</Base>
